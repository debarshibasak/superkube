# Copy to /etc/superkube/superkube.env and edit.
# Used by superkube-server.service and superkube-node.service.

# ---------- server ----------
# SQLite (default — single host):
DATABASE_URL=sqlite:///var/lib/superkube/superkube.db
# Postgres (multi-master):
# DATABASE_URL=postgres://superkube:secret@db.internal:5432/superkube

# Optional server flags also readable from CLI; set as env if you prefer:
# SUPERKUBE_HOST=0.0.0.0
# SUPERKUBE_PORT=6443
# SUPERKUBE_POD_CIDR=10.244.0.0/16
# SUPERKUBE_SERVICE_CIDR=10.96.0.0/12

# ---------- node ----------
# Required for superkube-node.service. URL of the control plane (or its LB).
SUPERKUBE_SERVER=http://127.0.0.1:6443

# auto / docker / embedded / mock
SUPERKUBE_RUNTIME=auto

# Override the node name (defaults to the host's short hostname).
# SUPERKUBE_NODE_NAME=worker-1
